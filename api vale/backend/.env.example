# Configuración de la base de datos PostgreSQL
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@localhost:5432/api_vale_db"

# JWT — Secreto para firmar los tokens (usar un valor aleatorio largo en producción)
JWT_SECRET="cambiar_este_secreto_en_produccion"
JWT_EXPIRES_IN="15m"

# Puerto del servidor
PORT=3000

# Entorno
NODE_ENV=development

# CORS — URL del frontend
ALLOWED_ORIGIN=http://localhost:5173
